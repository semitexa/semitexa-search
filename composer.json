{
    "name": "semitexa/search",
    "description": "Semitexa Search - structured search contracts, tenant-aware scoping, ORM backend, and optional LLM query planning",
    "version": "1.0.0",
    "type": "semitexa-module",
    "license": "MIT",
    "authors": [
        {
            "name": "Semitexa",
            "email": "support@semitexa.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "semitexa/core": "^1.0",
        "semitexa/orm": "^1.0",
        "semitexa/tenancy": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "semitexa/llm": "Required for LLM-assisted query planning"
    },
    "autoload": {
        "psr-4": {
            "Semitexa\\Search\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Semitexa\\Search\\Tests\\": "tests/"
        }
    },
    "extra": {
        "semitexa-module": {
            "template_alias": "semitexa-search"
        }
    },
    "keywords": [
        "semitexa",
        "search",
        "orm",
        "tenancy",
        "filtering"
    ]
}
